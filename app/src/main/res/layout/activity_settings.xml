<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/settingsBackBtn"
            android:text="← Back"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:padding="4dp" />

        <TextView
            android:text="Settings"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:letterSpacing="-0.02"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Customize your app experience"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Dark Theme -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Dark Theme"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Switch between dark and light mode"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="3dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <Switch
                    android:id="@+id/settingsThemeSwitch"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/accent_dim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Sound Effects -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Sound Effects"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Clicks, moves, wins and achievements"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="3dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <Switch
                    android:id="@+id/settingsSoundSwitch"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/accent_dim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Menu Music -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Menu Music"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Play background music on the main menu"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="3dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <Switch
                    android:id="@+id/settingsMusicSwitch"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/accent_dim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Splash duration -->
            <TextView
                style="@style/SectionLabel"
                android:text="Splash Screen Duration" />

            <RadioGroup
                android:id="@+id/splashDurationGroup"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/splash2s"
                    android:text="2 seconds"
                    android:textColor="@color/text_main"
                    android:buttonTint="@color/accent"
                    android:layout_marginEnd="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <RadioButton
                    android:id="@+id/splash5s"
                    android:text="5 seconds"
                    android:textColor="@color/text_main"
                    android:buttonTint="@color/accent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </RadioGroup>

            <Button
                android:id="@+id/resetSavedResultBtn"
                android:text="Clear Match History"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:background="@drawable/secondary_button"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>