<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="52dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/historyBackBtn"
        android:text="← Back"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:padding="4dp" />

    <TextView
        android:text="Match History"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="@color/text_main"
        android:letterSpacing="-0.02"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:text="Review your previous tournaments"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/emptyHistoryText"
        android:text="No tournaments saved yet.\nFinish a tournament and it will appear here automatically."
        android:textColor="@color/text_muted"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:background="@drawable/card_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/historyList"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/clearHistoryBtn"
        android:text="Clear History"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:background="@drawable/secondary_button"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:stateListAnimator="@null"
        android:elevation="0dp" />

</LinearLayout>