<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="32dp">

        <!-- ── Hero ── -->
        <TextView
            android:text="XO"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:letterSpacing="-0.03"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Tournament Arena"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:letterSpacing="-0.02"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Play · Compete · Win"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"
            android:letterSpacing="0.06"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- ── Setup card ── -->
        <LinearLayout
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Player names -->
            <TextView
                android:id="@+id/playerNamesLabel"
                style="@style/SectionLabel"
                android:text="Player Names" />

            <EditText
                android:id="@+id/playerXNameInput"
                android:hint="Player X name"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_muted"
                android:singleLine="true"
                android:backgroundTint="@color/border_bright"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/playerONameInput"
                android:hint="Player O name"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_muted"
                android:singleLine="true"
                android:backgroundTint="@color/border_bright"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="24dp" />
            <!-- Symbol picker -->
            <TextView
                style="@style/SectionLabel"
                android:text="Your Symbol" />

            <RadioGroup
                android:id="@+id/symbolGroup"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/symbolX"
                    android:text="✕  X"
                    android:checked="true"
                    android:textColor="@color/player_x"
                    android:buttonTint="@color/player_x"
                    android:textSize="15sp"
                    android:layout_marginEnd="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <RadioButton
                    android:id="@+id/symbolO"
                    android:text="○  O"
                    android:textColor="@color/player_o"
                    android:buttonTint="@color/player_o"
                    android:textSize="15sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </RadioGroup>

            <!-- Rounds -->
            <TextView
                style="@style/SectionLabel"
                android:text="Rounds" />

            <Spinner
                android:id="@+id/roundSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/border_bright"
                android:popupBackground="@color/surface_elevated" />

            <!-- Mode -->
            <TextView
                style="@style/SectionLabel"
                android:text="Game Mode" />

            <Spinner
                android:id="@+id/modeSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/border_bright"
                android:popupBackground="@color/surface_elevated" />

            <!-- Opponent -->
            <TextView
                style="@style/SectionLabel"
                android:text="Opponent" />

            <Spinner
                android:id="@+id/opponentSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="@color/border_bright"
                android:popupBackground="@color/surface_elevated" />

            <!-- AI difficulty (shown/hidden programmatically) -->
            <TextView
                android:id="@+id/aiLabel"
                style="@style/SectionLabel"
                android:text="AI Difficulty" />

            <Spinner
                android:id="@+id/aiSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="@color/border_bright"
                android:popupBackground="@color/surface_elevated" />

        </LinearLayout>

        <!-- ── CTA buttons ── -->
        <Button
            android:id="@+id/playBtn"
            android:text="Start Tournament"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            android:textSize="16sp"
            android:letterSpacing="0.02"
            android:background="@drawable/primary_button"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

        <Button
            android:id="@+id/loadBtn"
            android:text="Match History"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:background="@drawable/secondary_button"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:stateListAnimator="@null"
            android:elevation="0dp" />
        <Button
            android:id="@+id/statisticsBtn"
            android:text="Statistics"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <Button
            android:id="@+id/rulesBtn"
            android:text="Rules"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <Button
            android:id="@+id/settingsBtn"
            android:text="Settings"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>
</ScrollView>