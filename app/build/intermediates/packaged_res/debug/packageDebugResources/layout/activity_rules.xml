<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="52dp"
    android:paddingBottom="32dp">

    <!-- ── Back icon (use a real ImageButton in code) ── -->
    <TextView
        android:id="@+id/backBtn"
        android:text="← Back"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:letterSpacing="0.02"
        android:padding="4dp" />

    <!-- ── Title ── -->
    <TextView
        android:text="How to Play"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/text_main"
        android:letterSpacing="-0.02"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp" />

    <TextView
        android:text="Quick rules to get you started"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp" />

    <!-- ── Rules card ── -->
    <LinearLayout
        android:background="@drawable/card_bg"
        android:orientation="vertical"
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp">

        <!-- Rule items (each row is icon + text) -->
        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="18dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="⬜" android:textSize="20sp"
                android:layout_width="36dp" android:layout_height="wrap_content"/>
            <TextView android:text="The board is a 3 × 3 grid."
                android:textColor="@color/text_main" android:textSize="15sp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="18dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="🔄" android:textSize="20sp"
                android:layout_width="36dp" android:layout_height="wrap_content"/>
            <TextView android:text="Players alternate turns — X always goes first."
                android:textColor="@color/text_main" android:textSize="15sp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="18dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="🏅" android:textSize="20sp"
                android:layout_width="36dp" android:layout_height="wrap_content"/>
            <TextView android:text="Line up 3 symbols in a row, column, or diagonal to win."
                android:textColor="@color/text_main" android:textSize="15sp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="18dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="🤝" android:textSize="20sp"
                android:layout_width="36dp" android:layout_height="wrap_content"/>
            <TextView android:text="A full board with no winner is a draw."
                android:textColor="@color/text_main" android:textSize="15sp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="🏆" android:textSize="20sp"
                android:layout_width="36dp" android:layout_height="wrap_content"/>
            <TextView android:text="Scores accumulate across all tournament rounds. Most wins takes the crown."
                android:textColor="@color/text_main" android:textSize="15sp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>