<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main game screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <!-- Top row: round + mode chip -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/roundText"
                android:text="Round 1 / 5"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.04"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/modeText"
                android:text="Classic · PvP"
                style="@style/Chip" />

        </LinearLayout>

        <!-- Turn indicator -->
        <TextView
            android:id="@+id/statusText"
            android:text="X's turn"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/player_x"
            android:letterSpacing="-0.01"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:max="100"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/surface_elevated"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginBottom="20dp" />

        <!-- Score strip -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <!-- X score -->
            <LinearLayout
                style="@style/ScoreBox"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/xScoreNum"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/player_x"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="X"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/text_muted"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Draws -->
            <LinearLayout
                style="@style/ScoreBox"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/drawScoreNum"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/draw"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="DRAW"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/text_muted"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- O score -->
            <LinearLayout
                style="@style/ScoreBox"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/oScoreNum"
                    android:text="0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/player_o"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="O"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:textColor="@color/text_muted"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

        <!-- Leader label -->
        <TextView
            android:id="@+id/leaderText"
            android:text="Balanced"
            android:textSize="12sp"
            android:textColor="@color/text_dim"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- 3x3 Grid -->
        <GridLayout
            android:id="@+id/grid"
            android:columnCount="3"
            android:rowCount="3"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/cell0"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell1"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell2"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell3"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell4"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell5"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell6"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell7"
                style="@style/CellButton" />

            <Button
                android:id="@+id/cell8"
                style="@style/CellButton" />

        </GridLayout>

    </LinearLayout>

    <!-- Round transition overlay -->
    <LinearLayout
        android:id="@+id/roundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg"
        android:alpha="0"
        android:visibility="gone"
        android:padding="28dp">

        <TextView
            android:id="@+id/roundOverlayTitle"
            android:text="Round 2"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:gravity="center"
            android:letterSpacing="-0.02"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/roundOverlaySubtitle"
            android:text="Get ready..."
            android:textSize="16sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Leave tournament confirmation overlay -->
    <LinearLayout
        android:id="@+id/leaveOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone"
        android:alpha="0"
        android:padding="24dp">

        <LinearLayout
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Leave tournament?"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:letterSpacing="-0.02"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:text="Your current progress will be lost. Are you sure you want to return to the menu?"
                android:textSize="14sp"
                android:textColor="@color/text_muted"
                android:lineSpacingExtra="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/cancelLeaveBtn"
                android:text="Cancel"
                android:textColor="@color/text_main"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/primary_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <Button
                android:id="@+id/confirmLeaveBtn"
                android:text="Leave Tournament"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:background="@drawable/secondary_button"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>