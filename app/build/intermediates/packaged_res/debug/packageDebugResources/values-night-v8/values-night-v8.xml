<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent">#7C5CFC</color>
    <color name="accent_dim">#2A1E5C</color>
    <color name="accent_glow">#4D35B0</color>
    <color name="bg">#0A0A0F</color>
    <color name="border">#252535</color>
    <color name="border_bright">#3A3A55</color>
    <color name="danger">#FF4D6A</color>
    <color name="draw">#FFBE3D</color>
    <color name="player_o">#5CF0FC</color>
    <color name="player_o_dim">#0F3C40</color>
    <color name="player_x">#FC5C7D</color>
    <color name="player_x_dim">#4A1826</color>
    <color name="surface">#13131A</color>
    <color name="surface_elevated">#1C1C27</color>
    <color name="text_dim">#3A3A55</color>
    <color name="text_main">#F0F0FF</color>
    <color name="text_muted">#5A5A7A</color>
    <color name="win">#3DFF9A</color>
    <color name="win_dim">#0A3020</color>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:navigationBarDividerColor">@color/border</item>
    </style>
    <style name="CellButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/cell_bg</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">44sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>
    <style name="Chip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:background">@drawable/chip_bg</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    <style name="ScoreBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/score_box_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    <style name="SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>
</resources>