<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent">#6B46FA</color>
    <color name="accent_dim">#DDD8FF</color>
    <color name="accent_glow">#5035D0</color>
    <color name="bg">#F4F3FF</color>
    <color name="border">#E2DEFC</color>
    <color name="border_bright">#C5BEF5</color>
    <color name="danger">#E03131</color>
    <color name="draw">#D08A00</color>
    <color name="player_o">#0099B0</color>
    <color name="player_o_dim">#D0F4F9</color>
    <color name="player_x">#E8355A</color>
    <color name="player_x_dim">#FDDDE4</color>
    <color name="surface">#FFFFFF</color>
    <color name="surface_elevated">#EDEAFF</color>
    <color name="text_dim">#B0A8D4</color>
    <color name="text_main">#0E0B1F</color>
    <color name="text_muted">#7B72A8</color>
    <color name="win">#1A9E5C</color>
    <color name="win_dim">#D2F5E6</color>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/dm_sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:navigationBarDividerColor">@color/border</item>
    </style>
    <style name="CellButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/cell_bg</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">44sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>
    <style name="Chip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:background">@drawable/chip_bg</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    <style name="ScoreBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/score_box_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    <style name="SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>
</resources>